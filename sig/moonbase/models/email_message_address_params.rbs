module Moonbase
  module Models
    type email_message_address_params = { email: String, name: String }

    class EmailMessageAddressParams < Moonbase::Internal::Type::BaseModel
      attr_accessor email: String

      attr_reader name: String?

      def name=: (String) -> String

      def initialize: (email: String, ?name: String) -> void

      def to_hash: -> { email: String, name: String }
    end
  end
end
