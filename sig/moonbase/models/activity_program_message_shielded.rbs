        type: :"activity/program_message_shielded",
        reason_code: Moonbase::Models::ActivityProgramMessageShielded::reason_code
      }

      type reason_code =
        :person_previously_unsubscribed | :email_on_unsubscribe_list

      module ReasonCode
        extend Moonbase::Internal::Type::Enum

        PERSON_PREVIOUSLY_UNSUBSCRIBED: :person_previously_unsubscribed
        EMAIL_ON_UNSUBSCRIBE_LIST: :email_on_unsubscribe_list

