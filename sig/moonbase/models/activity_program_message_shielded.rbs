    class ActivityProgramMessageShielded < Moonbase::Internal::Type::BaseModel
      attr_accessor id: String

      attr_accessor occurred_at: Time

      attr_accessor program_message: Moonbase::Pointer?

      attr_accessor recipient: Moonbase::ItemPointer?

      attr_accessor type: :"activity/program_message_shielded"

      attr_reader reason_code: Moonbase::Models::ActivityProgramMessageShielded::reason_code?

      def reason_code=: (
        Moonbase::Models::ActivityProgramMessageShielded::reason_code
      ) -> Moonbase::Models::ActivityProgramMessageShielded::reason_code

      def initialize: (
        id: String,
        occurred_at: Time,
