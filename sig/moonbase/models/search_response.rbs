          data: Moonbase::Models::SearchResponse::Data::data,
          type: :search_result
        }

      class Data < Moonbase::Internal::Type::BaseModel
        attr_accessor data: Moonbase::Models::SearchResponse::Data::data

        attr_accessor type: :search_result

        def initialize: (
