          ?type: :search_result
        ) -> void

        def to_hash: -> {
          data: Moonbase::Models::SearchResponse::Data::data,
          type: :search_result
        }

        type data = Moonbase::Item | Moonbase::MoonbaseFile

        module Data
          extend Moonbase::Internal::Type::Union

          def self?.variants: -> ::Array[Moonbase::Models::SearchResponse::Data::data]
