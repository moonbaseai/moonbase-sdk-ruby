module Moonbase
  module Models
    module Collections
      type item_list_params =
        {
          collection_id: String,
          after: String,
          before: String,
          include: ::Array[String],
          limit: Integer,
          sort: ::Array[String]
        }
        & Moonbase::Internal::Type::request_parameters

      class ItemListParams < Moonbase::Internal::Type::BaseModel
        extend Moonbase::Internal::Type::RequestParameters::Converter
        include Moonbase::Internal::Type::RequestParameters

        attr_accessor collection_id: String

        attr_reader after: String?

        def after=: (String) -> String

        attr_reader before: String?

        def before=: (String) -> String

        attr_reader include: ::Array[String]?

        def include=: (::Array[String]) -> ::Array[String]

        attr_reader limit: Integer?

        def limit=: (Integer) -> Integer

        attr_reader sort: ::Array[String]?

        def sort=: (::Array[String]) -> ::Array[String]

        def initialize: (
          collection_id: String,
          ?after: String,
          ?before: String,
          ?include: ::Array[String],
          ?limit: Integer,
          ?sort: ::Array[String],
          ?request_options: Moonbase::request_opts
        ) -> void

        def to_hash: -> {
          collection_id: String,
          after: String,
          before: String,
          include: ::Array[String],
          limit: Integer,
          sort: ::Array[String],
          request_options: Moonbase::RequestOptions
        }
      end
    end
  end
end
